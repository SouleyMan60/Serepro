    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.15.0",
    "ts-jest": "^29.1.5",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  }
